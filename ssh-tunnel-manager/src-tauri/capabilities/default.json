{
  "identifier": "default",
  "description": "Default capabilities for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "path": "$RESOURCE/**",
          "sidecar": true
        }
      ]
    },
    "notification:default",
    "notification:allow-show"
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSH Tunnel Manager",
  "version": "0.1.7",
  "identifier": "com.ssh-tunnel-manager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSH Tunnel Manager",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "template": "./nsis/installer.nsi"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://your-server.com/api/version"],
      "pubkey": ""
    }
  }
}
